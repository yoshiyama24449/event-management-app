{
  "name": "Kubernetes Event App (Fast Startup)",
  // Codespaces標準の爆速イメージをそのまま使う
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    // 💡 起動速度への影響が最も少ない設定で、Dockerだけを有効化します
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true
    }
  },
  
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-kubernetes-tools.vscode-kubernetes-tools", // k8s用の便利GUI・補完
        "redhat.vscode-yaml"                           // YAMLの入力補完
      ]
    }
  }
}