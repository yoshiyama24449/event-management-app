# =========================================================================
# STAGE 1: ビルドステージ（アプリケーションの建築現場）
# =========================================================================
# この段階を「builder」という名前の仮の部屋として定義します。
# 軽量な Linux 環境（alpine）に Node.js 20 が入ったイメージを土台にします。
FROM node:20-alpine AS builder

# コンテナ内の作業部屋を「/app」に設定
WORKDIR /app

# ライブラリの定義ファイル（package.json / package-lock.json）を先にコピー
COPY package*.json ./

# 開発用ツールやコンパイラを含む、すべてのライブラリを一度インストールします
RUN npm install

# ソースコード（app/page.tsx など）をすべてコンテナにコピー
COPY . .

# Next.js のビルドコマンドを実行します。
# 💡 ここでソースコードが「.next」という名前の、ブラウザに配信するための
#    超軽量・最適化された本番用ファイル（HTML/CSS/JSの塊）に変換されます。
RUN npm run build


# =========================================================================
# STAGE 2: 実行用ステージ（本番用の綺麗に片付いたお部屋）
# =========================================================================
# まっさらな状態から、もう一度新しい Node.js 環境を「runner」として立ち上げます。
# 💡 STAGE 1 で使った巨大なソースコードや不要なコンパイラは、ここに引き継がれずすべて破棄されます。
FROM node:20-alpine AS runner

# コンテナ内の本番用作業部屋を「/app」に設定
WORKDIR /app

# --------------------------------────────────────-------------------------
# 【マルチステージビルドの核心】STAGE 1（builder）から必要な成果物だけを泥棒してくる
# -------------------------------------------------------------------------
# 先ほどビルドして作った、本番に必要な最小限の最適化データ（.next）だけをコピー
COPY --from=builder /app/.next ./.next

# 画像などの静的ファイルが入ったパブリックフォルダをコピー
COPY --from=builder /app/public ./public

# 起動コマンド（npm start）を認識させるために設定ファイルをコピー
COPY --from=builder /app/package.json ./package.json

# 本番の実行にどうしても必要な最小限のライブラリだけをコピー
COPY --from=builder /app/node_modules ./node_modules


# =========================================================================
# 3. 本番用サーバーの起動コマンド
# =========================================================================
# 綺麗に片付いた runner コンテナが立ち上がった瞬間に、本番用サーバーを起動します。
# 💡 開発環境（npm run dev）と違い、すでにビルド済みの軽量なデータを高速に配信するモード（npm start）で動かします。
CMD ["npm", "start"]