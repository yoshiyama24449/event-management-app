# =========================================================================
# 1. ベースイメージ（環境の土台）の決定
# =========================================================================
# Python 3.11 が最初から入っている Linux 環境をベースにします。
# 「-slim」を選ぶことで、余計なツールを削ぎ落とした軽量な本番向けの環境になります。
FROM python:3.11-slim

# =========================================================================
# 2. コンテナ内の作業部屋（ディレクトリ）の作成と移動
# =========================================================================
# コンテナの中に「/app」というフォルダを作り、そこを基準にコマンドを実行するようにします。
# これ以降、ファイルはすべてこのフォルダの中に配置・実行されます。
WORKDIR /app

# =========================================================================
# 3. ライブラリ（依存関係）のインストール ➔ 【Dockerキャッシュを活かすコツ】
# =========================================================================
# まず、ライブラリの一覧が書かれた「requirements.txt」だけを先にコンテナにコピーします。
COPY requirements.txt .

# 「pip install」を実行して、FastAPI や SQLAlchemy などのライブラリをインストールします。
# --no-cache-dir をつけることで、コンテナ内に無駄なゴミ（キャッシュ）を残さずサイズを小さく抑えます。
# 💡 プログラムコード（main.py等）のコピーより前にこれをやることで、
#    コードを書き換えるたびに重いインストール処理が毎回走るのを防いでいます（爆速起動の秘密）。
RUN pip install --no-cache-dir -r requirements.txt

# =========================================================================
# 4. プログラムコードのコピー
# =========================================================================
# ホスト側（あなたの手元）のバックエンドフォルダにあるすべてのファイルを、コンテナの「/app」へ丸ごとコピーします。
# これで最新の main.py や database.py がコンテナ内に配置されます。
COPY . .

# =========================================================================
# 5. ポート番号の明記（ドキュメント用）
# =========================================================================
# このコンテナが外と通信するために「8000番ポート」を使うことを明記します。
# これ自体に通信を開放する強制力はありませんが、ネットワーク設計上の大事なサインになります。
EXPOSE 8000

# =========================================================================
# 6. コンテナ起動時に自動実行するコマンド
# =========================================================================
# コンテナが立ち上がった瞬間に、PythonのWebサーバー（Uvicorn）を起動してアプリを開始します。
# 
# 【引数の解説】
#  - "main:app"       : main.py の中にある app = FastAPI() を動かしなさいという指示
#  - "--host", "0.0.0.0" : コンテナの「外（他のコンテナ等）」からの通信をすべて受け付けるための必須設定
#  - "--port", "8000"    : 8000番ポートで待ち受ける
#  - "--reload"          : ホットリロード有効化。手元でファイルを保存したら自動でアプリが再起動する（開発用）
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]